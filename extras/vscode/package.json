{
  "name": "ade-syntax",
  "displayName": "ADE Syntax Highlighting",
  "description": "Syntax highlighting for Architecture Decision Rule files",
  "version": "1.0.0",
  "publisher": "adr",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/adr/ad-guidance-tool"
  },
  "scripts": {
    "package": "vsce package --out ade-syntax.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "engines": {
    "vscode": "^1.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "ade-syntax",
        "aliases": ["ADE Syntax", "ade-syntax"],
        "extensions": [".rule"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ade-syntax",
        "scopeName": "source.ade-syntax",
        "path": "./syntaxes/ade-syntax.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ade-syntax",
        "path": "./snippets/ade-syntax.json"
      }
    ]
  }
}
